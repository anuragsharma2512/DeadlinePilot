# Server Configuration
PORT=5000
JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173

# Database Configuration
# For local SQLite: file:lifesaver.db
# For production (Turso): libsql://your-db-name.turso.io
DATABASE_URL=file:lifesaver.db
DATABASE_AUTH_TOKEN=

# AI Configuration
# Google Gemini API Key (from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
# Comma-separated fallback list. If the first model is unavailable, the server tries the next.
GEMINI_MODEL=gemini-2.5-flash,gemini-2.0-flash
